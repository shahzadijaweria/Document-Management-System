# Copy this to a top-level `.env` (NOT committed) and fill in real values.
# docker-compose reads these and passes them to the backend container.

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 — same values you'd put in backend/.env
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Note: DATABASE_URL and REDIS_HOST are NOT here — docker-compose hardcodes them
# to point at the postgres + redis containers via their service names.

# Frontend public URLs (baked into the client bundle at build time).
# Local dev: leave commented out, defaults to http://localhost:4000.
# EC2 deploy: set BOTH to your Elastic IP, e.g.:
#   NEXT_PUBLIC_API_URL=http://3.122.45.67:4000
#   NEXT_PUBLIC_SOCKET_URL=http://3.122.45.67:4000
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_SOCKET_URL=
