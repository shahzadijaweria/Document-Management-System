// Prisma schema for the DMS.
// DATABASE_URL is supplied via prisma.config.ts (loads .env), not via env() here.
// Generated client lives at src/generated/prisma (gitignored).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────
enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  documents     Document[]
  notifications Notification[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────────────────────────────
model Document {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?
  categoryId  String?  @map("category_id")
  s3Key       String   @map("s3_key")
  s3Url       String   @map("s3_url")
  fileSize    Int      @map("file_size")
  fileType    String   @map("file_type")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([categoryId])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────────────────────────
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String
  createdAt DateTime @default(now()) @map("created_at")

  documents Document[]

  @@map("categories")
}

// ─────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}
