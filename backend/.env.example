# ──────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ──────────────────────────────────────────────────────────────
# Database (PostgreSQL via Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dms?schema=public

# ──────────────────────────────────────────────────────────────
# JWT Authentication
# Generate strong secrets with: openssl rand -base64 64
# Use DIFFERENT secrets for access and refresh tokens
# ──────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────────────────────────
# AWS S3
# Create IAM user with S3 read/write policy on the bucket only
# Never commit real credentials
# ──────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=dms-documents

# ──────────────────────────────────────────────────────────────
# Redis
# Leave REDIS_PASSWORD empty for local dev (no auth)
# ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ──────────────────────────────────────────────────────────────
# CORS — frontend origin allowed to call this API
# ──────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Logging
# Levels: error, warn, info, http, verbose, debug, silly
# ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
