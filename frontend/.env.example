# Frontend environment variables.
# Copy this to `.env.local` (which is gitignored) and adjust values as needed.
#
# The NEXT_PUBLIC_ prefix is REQUIRED for Next.js to expose a variable to the
# browser bundle. They get baked in at BUILD time — change them and rebuild.

# Backend API base URL (Express server)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Backend Socket.io URL — usually the same host as the API
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
